{
  "name": "jammming-monorepo",
  "private": true,
  "scripts": {
    "client-dev": "npm --prefix client run dev",
    "client-test": "npm --prefix client run test",
    "server-dev": "npm --prefix server run dev",
    "server-test": "npm --prefix server run test",
    "build": "npm --prefix client run build",
    "install:all": "npm install && npm --prefix client install && npm --prefix server install",
    "start": "npm --prefix server run start"
  }
}